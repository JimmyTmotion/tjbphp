# BBSensory stats dashboard database connection.
# Recommended: use separate fields so passwords do not need URL encoding.
# For local/shared hosting, Supabase's pooler session mode host usually works better than the direct db.* host because it supports IPv4.
BBAPP_DB_HOST="aws-0-[REGION].pooler.supabase.com"
BBAPP_DB_PORT="5432"
BBAPP_DB_NAME="postgres"
BBAPP_DB_USER="postgres.[PROJECT-REF]"
BBAPP_DB_PASSWORD="[YOUR-PASSWORD]"
BBAPP_DB_SSLMODE="require"

# Alternative: one connection string. Password special characters must be URL-encoded.
# BBAPP_DATABASE_URL="postgresql://postgres:[YOUR-ENCODED-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Strongly recommended before deploying /bbapp publicly.
# When set, the dashboard uses HTTP Basic Auth with username "admin" and this password.
BBAPP_DASHBOARD_PASSWORD="change-this-password"
